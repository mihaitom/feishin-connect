# Targets — kommagetrennt, Format: typ:name
# Sonos:   sonos:Raumname    (exakt wie in der Sonos App)
# AirPlay: airplay:Gerätname (exakt wie im Netzwerk)
TARGETS=sonos:Arbeitszimmer,airplay:HomePod Küche

# Server
HOST=0.0.0.0
PORT=8765

# Debug-Logging — ausführliche Playback-Logs für ALLE Renderer (AirPlay + Sonos)
# DEBUG=true
